@model IEnumerable<InventoryPro.Models.Product>
@{
    ViewData["Title"] = "Low Stock Report";
    int totalLowStock = ViewBag.TotalLowStock ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">
            <i class="bi bi-exclamation-triangle me-2 text-danger"></i>
            Low Stock Report
        </h2>
        <p class="text-muted mb-0">
            <span class="text-danger fw-bold">@totalLowStock product(s)</span>
            are at or below reorder level
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="ExportLowStockPdf" class="btn btn-danger">
            <i class="bi bi-file-earmark-pdf me-2"></i>Export PDF
        </a>
        <button onclick="window.print()" class="btn btn-outline-secondary">
            <i class="bi bi-printer me-2"></i>Print
        </button>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center p-5">
            <i class="bi bi-check-circle text-success" style="font-size:4rem;"></i>
            <h4 class="mt-3 text-success">All Stock Levels are Healthy!</h4>
            <p class="text-muted">
                No products are currently below their reorder level.
            </p>
            <a asp-controller="Dashboard" asp-action="Index"
               class="btn btn-primary mt-2">
                <i class="bi bi-speedometer2 me-2"></i>Back to Dashboard
            </a>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger shadow-sm">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Action Required:</strong>
        The following @totalLowStock product(s) need to be restocked urgently.
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Product Name</th>
                            <th>Supplier</th>
                            <th class="text-center">In Stock</th>
                            <th class="text-center">Reorder Level</th>
                            <th class="text-center">Shortage</th>
                            <th class="text-center">Recommended Order</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            int shortage = product.ReorderLevel
                            - product.QuantityInStock;
                            int recommendedOrder = (product.ReorderLevel * 3)
                            - product.QuantityInStock;
                            <tr class="table-danger">
                                <td>
                                    <span class="badge bg-secondary">
                                        @product.ProductID
                                    </span>
                                </td>
                                <td>
                                    <strong>@product.ProductName</strong>
                                    @if (!string.IsNullOrEmpty(product.Description))
                                    {
                                        <br />
                                        <small class="text-muted">
                                            @product.Description
                                        </small>
                                    }
                                </td>
                                <td>
                                    <small>@(product.Supplier ?? "—")</small>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-danger fs-6">
                                        @product.QuantityInStock
                                    </span>
                                </td>
                                <td class="text-center text-muted">
                                    @product.ReorderLevel
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-warning text-dark">
                                        @shortage unit(s) short
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary fs-6">
                                        Order @recommendedOrder
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a asp-controller="Product"
                                       asp-action="Edit"
                                       asp-route-id="@product.ProductID"
                                       class="btn btn-sm btn-warning text-dark">
                                        <i class="bi bi-pencil me-1"></i>
                                        Update Stock
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}