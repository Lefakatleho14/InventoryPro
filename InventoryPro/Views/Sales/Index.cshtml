@model IEnumerable<InventoryPro.Models.Sale>
@{
    ViewData["Title"] = "Sales History";
    decimal totalRevenue = ViewBag.TotalRevenue ?? 0m;
    int totalItems = ViewBag.TotalItems ?? 0;
}

<!-- ── Page Header ── -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">
            <i class="bi bi-receipt me-2 text-primary"></i>Sales History
        </h2>
        <p class="text-muted mb-0">
            @Model.Count() transaction(s) &nbsp;|&nbsp;
            Total Revenue: <strong class="text-success">R @totalRevenue.ToString("N2")</strong>
        </p>
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-cart-plus me-2"></i>Record New Sale
    </a>
</div>

<!-- ── Filter Bar ── -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-semibold">From Date</label>
                <input type="date" name="startDate" class="form-control"
                       value="@ViewBag.StartDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">To Date</label>
                <input type="date" name="endDate" class="form-control"
                       value="@ViewBag.EndDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Product Name</label>
                <input type="text" name="searchProduct" class="form-control"
                       placeholder="Search product..."
                       value="@ViewBag.SearchProduct" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-search me-1"></i>Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                    <i class="bi bi-x-circle me-1"></i>Clear
                </a>
            </div>
        </form>
    </div>
</div>

<!-- ── Summary Cards ── -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card bg-success text-white text-center p-3 shadow-sm">
            <div class="fs-3 fw-bold">R @totalRevenue.ToString("N2")</div>
            <small>Total Revenue</small>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-primary text-white text-center p-3 shadow-sm">
            <div class="fs-3 fw-bold">@Model.Count()</div>
            <small>Total Transactions</small>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-warning text-dark text-center p-3 shadow-sm">
            <div class="fs-3 fw-bold">@totalItems</div>
            <small>Total Items Sold</small>
        </div>
    </div>
</div>

<!-- ── Sales Table ── -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center p-5 text-muted">
                <i class="bi bi-cart-x fs-1"></i>
                <p class="mt-3 fs-5">No sales found for the selected filters.</p>
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-cart-plus me-2"></i>Record First Sale
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Sale ID</th>
                            <th>Date & Time</th>
                            <th>Product</th>
                            <th class="text-center">Qty Sold</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Total Price</th>
                            <th>Served By</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sale in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">#@sale.SaleID</span>
                                </td>
                                <td>
                                    <span>@sale.SaleDate.ToString("dd MMM yyyy")</span>
                                    <br />
                                    <small class="text-muted">
                                        @sale.SaleDate.ToString("HH:mm")
                                    </small>
                                </td>
                                <td>
                                    <strong>@sale.Product?.ProductName</strong>
                                    <br />
                                    <small class="text-muted">
                                        ID: @sale.Product?.ProductID
                                    </small>
                                </td>
                                <td class="text-center fw-bold">@sale.QuantitySold</td>
                                <td class="text-end text-muted">
                                    R @sale.Product?.UnitPrice.ToString("N2")
                                </td>
                                <td class="text-end fw-bold text-success">
                                    R @sale.TotalPrice.ToString("N2")
                                </td>
                                <td>
                                    <small>@sale.User?.FullName</small>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Receipt"
                                           asp-route-id="@sale.SaleID"
                                           class="btn btn-outline-success"
                                           title="View Receipt">
                                            <i class="bi bi-receipt"></i>
                                        </a>
                                        <a asp-action="Details"
                                           asp-route-id="@sale.SaleID"
                                           class="btn btn-outline-info"
                                           title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td colspan="5" class="text-end">Totals:</td>
                            <td class="text-end text-success">
                                R @Model.Sum(s => s.TotalPrice).ToString("N2")
                            </td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>