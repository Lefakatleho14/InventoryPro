@model InventoryPro.Models.Sale
@{
    ViewData["Title"] = "Sale Receipt";
}

<div class="row justify-content-center">
    <div class="col-lg-6">

        <!-- Print button (hidden when printing) -->
        <div class="d-flex justify-content-between mb-3 no-print">
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-cart-plus me-2"></i>New Sale
            </a>
            <button onclick="window.print()" class="btn btn-primary">
                <i class="bi bi-printer me-2"></i>Print Receipt
            </button>
        </div>

        <!-- Receipt Card -->
        <div class="card shadow" id="receiptCard">
            <!-- Header -->
            <div class="card-body text-center border-bottom pb-3">
                <h4 class="fw-bold text-primary mb-0">
                    <i class="bi bi-box-seam me-2"></i>InventoryPro
                </h4>
                <p class="text-muted mb-0">Durban Small Business Supplies</p>
                <p class="text-muted small mb-0">123 Smith Street, Durban, 4001</p>
                <hr />
                <h5 class="mb-0">SALE RECEIPT</h5>
                <p class="text-muted small">
                    Receipt #@Model.SaleID
                </p>
            </div>

            <div class="card-body">
                <!-- Sale Info -->
                <div class="row mb-3">
                    <div class="col-6">
                        <small class="text-muted d-block">Date</small>
                        <strong>@Model.SaleDate.ToString("dd MMM yyyy")</strong>
                    </div>
                    <div class="col-6 text-end">
                        <small class="text-muted d-block">Time</small>
                        <strong>@Model.SaleDate.ToString("HH:mm")</strong>
                    </div>
                    <div class="col-6 mt-2">
                        <small class="text-muted d-block">Served By</small>
                        <strong>@Model.User?.FullName</strong>
                    </div>
                    <div class="col-6 mt-2 text-end">
                        <small class="text-muted d-block">Sale ID</small>
                        <strong>#@Model.SaleID</strong>
                    </div>
                </div>

                <!-- Item Table -->
                <table class="table table-bordered mb-3">
                    <thead class="table-dark">
                        <tr>
                            <th>Product</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <strong>@Model.Product?.ProductName</strong>
                                <br />
                                <small class="text-muted">
                                    ID: @Model.Product?.ProductID
                                </small>
                            </td>
                            <td class="text-center">@Model.QuantitySold</td>
                            <td class="text-end">
                                R @Model.Product?.UnitPrice.ToString("N2")
                            </td>
                            <td class="text-end fw-bold">
                                R @Model.TotalPrice.ToString("N2")
                            </td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr class="table-success">
                            <td colspan="3" class="text-end fw-bold fs-5">
                                TOTAL PAID:
                            </td>
                            <td class="text-end fw-bold fs-5 text-success">
                                R @Model.TotalPrice.ToString("N2")
                            </td>
                        </tr>
                    </tfoot>
                </table>

                <!-- Thank you message -->
                <div class="text-center mt-3 pt-3 border-top">
                    <p class="text-muted small mb-1">
                        Thank you for your purchase!
                    </p>
                    <p class="text-muted small mb-0">
                        Goods sold are not returnable without original receipt.
                    </p>
                    <div class="mt-3 text-muted" style="font-size: 0.7rem;">
                        *** InventoryPro — Powered by CodeCrafters ***
                    </div>
                </div>
            </div>
        </div>

        <!-- Back buttons -->
        <div class="d-flex gap-2 mt-3 no-print">
            <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                <i class="bi bi-list-ul me-2"></i>Sales History
            </a>
            <a asp-controller="Dashboard" asp-action="Index"
               class="btn btn-outline-primary flex-fill">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <style>
        @@media print {
            .no-print, nav, .navbar {
                display: none !important;
            }

            .card {
                border: 1px solid #000 !important;
                box-shadow: none !important;
            }

            body {
                background: white !important;
            }
        }
    </style>
}