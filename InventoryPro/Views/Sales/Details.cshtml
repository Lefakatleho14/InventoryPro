@model InventoryPro.Models.Sale
@{
    ViewData["Title"] = "Sale Details";
}

<div class="row justify-content-center">
    <div class="col-lg-6">

        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a asp-action="Index">Sales History</a>
                </li>
                <li class="breadcrumb-item active">Sale #@Model.SaleID</li>
            </ol>
        </nav>

        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="bi bi-info-circle me-2"></i>
                    Sale Details — #@Model.SaleID
                </h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <td class="fw-semibold text-muted">Sale ID</td>
                        <td><span class="badge bg-secondary">#@Model.SaleID</span></td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Date & Time</td>
                        <td>@Model.SaleDate.ToString("dd MMMM yyyy HH:mm")</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Product</td>
                        <td>
                            <strong>@Model.Product?.ProductName</strong>
                            <span class="badge bg-secondary ms-2">
                                ID: @Model.Product?.ProductID
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Quantity Sold</td>
                        <td class="fw-bold">@Model.QuantitySold units</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Unit Price</td>
                        <td>R @Model.Product?.UnitPrice.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Total Price</td>
                        <td class="fw-bold text-success fs-5">
                            R @Model.TotalPrice.ToString("N2")
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Served By</td>
                        <td>@Model.User?.FullName</td>
                    </tr>
                </table>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Receipt" asp-route-id="@Model.SaleID"
                   class="btn btn-success">
                    <i class="bi bi-receipt me-2"></i>View Receipt
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary ms-auto">
                    <i class="bi bi-arrow-left me-2"></i>Back to Sales
                </a>
            </div>
        </div>
    </div>
</div>