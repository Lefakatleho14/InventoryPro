<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – InventoryPro</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- ── Top Navigation Bar ── -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container-fluid">

                <!-- Brand -->
                <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-box-seam me-2"></i>InventoryPro
                </a>

                <!-- Mobile toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <!-- Left nav links -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">
                                <i class="bi bi-archive me-1"></i>Products
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Sales" asp-action="Create">
                                <i class="bi bi-cart-plus me-1"></i>Record Sale
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Sales" asp-action="Index">
                                <i class="bi bi-receipt me-1"></i>Sales History
                            </a>
                        </li>

                        @if (User.IsInRole("Manager"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown">
                                    <i class="bi bi-bar-chart me-1"></i>Reports
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Report" asp-action="Sales">
                                            <i class="bi bi-graph-up me-2"></i>Sales Report
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Report" asp-action="Valuation">
                                            <i class="bi bi-currency-dollar me-2"></i>Inventory Valuation
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Report" asp-action="LowStock">
                                            <i class="bi bi-exclamation-triangle me-2"></i>Low Stock Report
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <!-- Right side: user info + logout -->
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>
                                @User.FindFirst("FullName")?.Value
                                <span class="badge bg-warning text-dark ms-1" style="font-size:0.65rem;">
                                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                </span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Account"
                                       asp-action="ChangePassword">
                                        <i class="bi bi-key me-2"></i>Change Password
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Account"
                                       asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- ── Main Content ── -->
        <div class="container-fluid py-4 px-4">

            <!-- Success / Error alert banners -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    }
    else
    {
        <!-- Not logged in: render page without navbar -->
        @RenderBody()
    }

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>